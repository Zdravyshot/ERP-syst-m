// ERP Zdravý shot — dátový model
// Peniaze: integer centy. Množstvá: Float. Žiadne DB enumy (SQLite → Postgres prenosnosť),
// povolené hodnoty stráži zod v src/lib/zod-schemas.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("user") // "admin" | "user"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------- Klienti ----------

model Client {
  id        String   @id @default(cuid())
  type      String // "B2B" | "B2C"
  name      String
  ico       String? // IČO
  dic       String? // DIČ
  icDph     String? // IČ DPH
  email     String?
  phone     String?
  iban      String?
  street    String?
  city      String?
  zip       String?
  country   String   @default("SK")
  note      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]
  invoices      Invoice[]
  subscriptions Subscription[]

  @@index([iban])
}

// ---------- Firemný a daňový profil ----------

model CompanyProfile {
  id        String    @id @default(cuid())
  legalName String
  tradeName String?
  ico       String
  dic       String
  icDph     String?
  email     String
  phone     String?
  street    String
  city      String
  zip       String
  country   String    @default("SK")
  validFrom DateTime
  validTo   DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  taxProfiles  TaxProfile[]
  bankAccounts BankAccount[]

  @@index([validFrom, validTo])
}

model TaxProfile {
  id                    String         @id @default(cuid())
  companyProfileId      String
  companyProfile        CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Restrict)
  vatStatus             String         @default("NON_PAYER") // "NON_PAYER" | "PAYER"
  vatRegisteredFrom     DateTime?
  domesticTaxMode       String         @default("STANDARD") // "STANDARD" | "EXEMPT"
  validFrom             DateTime
  validTo               DateTime?
  accountantConfirmedAt DateTime?
  accountantConfirmedBy String?
  note                  String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@unique([companyProfileId, validFrom])
  @@index([validFrom, validTo])
}

// ---------- Katalóg ----------

model Product {
  id            String   @id @default(cuid())
  sku           String   @unique // "ZS-060"
  name          String // "Zázvorový shot 60ml"
  volumeMl      Int?
  unit          String   @default("ks") // "ks" | "kg" | "l" | "g" | "ml"
  priceB2cCents Int
  priceB2bCents Int
  vatRate       Int      @default(20)
  minStock      Float    @default(0)
  shelfLifeDays Int      @default(30)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recipe            Recipe?
  batches           ProductionBatch[]
  orderItems        OrderItem[]
  movements         StockMovement[]
  subscriptionItems SubscriptionItem[]
  ekasaSales        EkasaSale[]
  vatRates          ProductVatRate[]
  invoiceItems      InvoiceItem[]
}

model ProductVatRate {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  rate        Int
  validFrom   DateTime
  validTo     DateTime?
  confirmedAt DateTime?
  confirmedBy String?
  sourceNote  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, validFrom])
  @@index([validFrom, validTo])
}

model Material {
  id             String   @id @default(cuid())
  name           String // "Zázvor čerstvý"
  unit           String // "kg" | "l" | "ks" | "g" | "ml"
  minStock       Float    @default(0)
  lastPriceCents Int      @default(0) // posledná nákupná cena za jednotku
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  recipeItems RecipeItem[]
  movements   StockMovement[]
}

// ---------- Výroba ----------

model Recipe {
  id        String   @id @default(cuid())
  productId String   @unique // 1 aktívna receptúra na produkt (v1)
  product   Product  @relation(fields: [productId], references: [id])
  batchSize Int // počet kusov na štandardnú dávku
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items RecipeItem[]
}

model RecipeItem {
  id         String   @id @default(cuid())
  recipeId   String
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Float // množstvo suroviny na batchSize kusov

  @@unique([recipeId, materialId])
}

model ProductionBatch {
  id             String   @id @default(cuid())
  batchNumber    String   @unique // "S2026-0042"
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  producedQty    Int
  productionDate DateTime
  expiryDate     DateTime
  status         String   @default("PLANNED") // "PLANNED" | "DONE" | "CANCELLED"
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  movements StockMovement[]
}

// ---------- Sklad: pohybový ledger ----------
// Presne jedno z materialId/productId je vyplnené (stráži app kód).
// Stav zásob = SUM(quantity) — quantity je signed (+príjem / −výdaj).

model StockMovement {
  id             String           @id @default(cuid())
  type           String // "PRIJEM" | "VYDAJ" | "VYROBA" | "SPOTREBA" | "PREDAJ" | "KOREKCIA"
  materialId     String?
  material       Material?        @relation(fields: [materialId], references: [id])
  productId      String?
  product        Product?         @relation(fields: [productId], references: [id])
  quantity       Float // signed
  batchId        String?
  batch          ProductionBatch? @relation(fields: [batchId], references: [id])
  orderId        String?
  order          Order?           @relation(fields: [orderId], references: [id])
  unitPriceCents Int? // nákladová cena pri príjme
  note           String?
  createdById    String?
  createdAt      DateTime         @default(now())

  @@index([materialId])
  @@index([productId])
}

// ---------- Objednávky a predplatné ----------

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique // "OBJ2026-0001"
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  channel        String        @default("MANUAL") // "MANUAL" | "EMAIL" | "WEB" | "SUBSCRIPTION"
  status         String        @default("NOVA") // "NOVA" | "POTVRDENA" | "VO_VYROBE" | "EXPEDOVANA" | "DORUCENA" | "ZRUSENA"
  orderDate      DateTime      @default(now())
  deliveryDate   DateTime?
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  inboxMessageId String?       @unique
  inboxMessage   InboxMessage? @relation(fields: [inboxMessageId], references: [id])
  externalId     String? // ID objednávky vo webovom e-shope
  note           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items     OrderItem[]
  invoices  Invoice[]
  movements StockMovement[]
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  quantity       Int
  unitPriceCents Int // snapshot ceny v čase objednávky
  vatRate        Int     @default(20)
}

model Subscription {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  frequency   String // "WEEKLY" | "BIWEEKLY" | "MONTHLY"
  nextRunDate DateTime
  isActive    Boolean  @default(true)
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items  SubscriptionItem[]
  orders Order[]
}

model SubscriptionItem {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  quantity       Int

  @@unique([subscriptionId, productId])
}

// ---------- Inbox (budúci e-mail parsing + web formulár) ----------

model InboxMessage {
  id         String   @id @default(cuid())
  source     String // "EMAIL" | "WEB_FORM" | "MANUAL"
  fromEmail  String?
  subject    String?
  body       String
  rawJson    String? // pôvodný payload pre neskoršie spracovanie
  status     String   @default("NOVA") // "NOVA" | "SPRACOVANA" | "IGNOROVANA"
  receivedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  order Order?
}

// ---------- Financie ----------
// Jednotná evidencia faktúr: interné + import z webu, SuperFaktúry a Omegy.
// invoiceNumber sa prideľuje až pri finalizácii, preto je pri koncepte null.
// @@unique([source, externalId]) → idempotentný import bez duplikátov.

model Invoice {
  id                   String    @id @default(cuid())
  direction            String // "VYDANA" | "PRIJATA"
  documentType         String    @default("INVOICE") // "INVOICE" | "CREDIT_NOTE"
  documentStatus       String    @default("ISSUED") // "DRAFT" | "ISSUED" | "CANCELLED"
  source               String    @default("INTERNA") // "INTERNA" | "WEB" | "SUPERFAKTURA" | "OMEGA"
  externalId           String? // ID v zdrojovom systéme
  externalNumber       String? // číslo faktúry v zdrojovom systéme
  invoiceNumber        String?   @unique // vydaná: "2026009"; pri koncepte null
  currency             String    @default("EUR")
  clientId             String?
  client               Client?   @relation(fields: [clientId], references: [id])
  supplierName         String? // legacy zobrazenie prijatej faktúry
  orderId              String?
  order                Order?    @relation(fields: [orderId], references: [id])
  originalInvoiceId    String?
  originalInvoice      Invoice?  @relation("InvoiceCreditNotes", fields: [originalInvoiceId], references: [id], onDelete: Restrict)
  creditNotes          Invoice[] @relation("InvoiceCreditNotes")
  issueDate            DateTime
  dueDate              DateTime
  deliveryDate         DateTime?
  finalizedAt          DateTime?
  cancelledAt          DateTime?
  cancelReason         String?
  createdById          String?
  finalizedById        String?
  cancelledById        String?
  status               String    @default("VYSTAVENA") // legacy do migrácie UI v A1
  totalNetCents        Int
  totalVatCents        Int
  totalGrossCents      Int
  variableSymbol       String?
  issuerSnapshot       Json?
  counterpartySnapshot Json?
  taxSnapshot          Json?
  note                 String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  items              InvoiceItem[]
  paymentAllocations PaymentAllocation[]
  documents          DocumentAsset[]
  emailDeliveries    EmailDelivery[]

  @@unique([source, externalId])
  @@index([direction, documentStatus, issueDate])
  @@index([originalInvoiceId])
}

model InvoiceItem {
  id              String   @id @default(cuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  lineNumber      Int      @default(1)
  description     String
  productSku      String?
  quantity        Float
  unit            String   @default("ks")
  unitPriceCents  Int
  vatRate         Int      @default(20)
  totalNetCents   Int?
  totalVatCents   Int?
  totalGrossCents Int?
  taxCategory     String? // napr. "STANDARD" | "EXEMPT"

  @@index([invoiceId, lineNumber])
}

model Payment {
  id                String           @id @default(cuid())
  direction         String           @default("INCOMING") // "INCOMING" | "OUTGOING"
  source            String           @default("MANUAL") // "MANUAL" | "BANK_IMPORT" | "TATRA_PREMIUM"
  amountCents       Int
  currency          String           @default("EUR")
  paidAt            DateTime
  reference         String?
  variableSymbol    String?
  counterpartyName  String?
  counterpartyIban  String?
  bankTransactionId String?          @unique
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id], onDelete: Restrict)
  note              String?
  createdById       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  allocations PaymentAllocation[]

  @@index([variableSymbol, currency, amountCents])
  @@index([paidAt])
}

model PaymentAllocation {
  id            String    @id @default(cuid())
  paymentId     String
  payment       Payment   @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  invoiceId     String
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  amountCents   Int
  createdById   String?
  createdAt     DateTime  @default(now())
  reversedAt    DateTime?
  reversedById  String?
  reverseReason String?

  @@unique([paymentId, invoiceId])
  @@index([invoiceId, reversedAt])
}

model BankConnection {
  id                    String    @id @default(cuid())
  provider              String // "TATRA_PREMIUM" | "STATEMENT_IMPORT"
  status                String    @default("DISCONNECTED") // "CONNECTED" | "DISCONNECTED" | "REAUTH_REQUIRED" | "ERROR"
  consentId             String?
  encryptedRefreshToken String?
  tokenKeyVersion       String?
  tokenExpiresAt        DateTime?
  syncCursor            String?
  lastSyncedAt          DateTime?
  lastError             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts     BankAccount[]
  transactions BankTransaction[]
}

model BankAccount {
  id                String          @id @default(cuid())
  companyProfileId  String?
  companyProfile    CompanyProfile? @relation(fields: [companyProfileId], references: [id], onDelete: Restrict)
  bankConnectionId  String?
  bankConnection    BankConnection? @relation(fields: [bankConnectionId], references: [id], onDelete: SetNull)
  providerAccountId String?
  name              String
  iban              String
  bic               String?
  currency          String          @default("EUR")
  isPrimary         Boolean         @default(false)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  transactions BankTransaction[]

  @@unique([iban, currency])
  @@unique([bankConnectionId, providerAccountId])
}

model BankTransaction {
  id                    String         @id @default(cuid())
  bankConnectionId      String
  bankConnection        BankConnection @relation(fields: [bankConnectionId], references: [id], onDelete: Restrict)
  bankAccountId         String
  bankAccount           BankAccount    @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  providerTransactionId String
  status                String         @default("BOOKED") // "PENDING" | "BOOKED"
  bookingDate           DateTime
  valueDate             DateTime?
  amountCents           Int
  currency              String         @default("EUR")
  counterpartyName      String?
  counterpartyIban      String?
  variableSymbol        String?
  constantSymbol        String?
  specificSymbol        String?
  remittanceInfo        String?
  rawPayload            Json?
  importedAt            DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  payment Payment?

  @@unique([bankConnectionId, providerTransactionId])
  @@index([bankAccountId, bookingDate])
  @@index([variableSymbol, currency, amountCents])
}

model DocumentAsset {
  id              String    @id @default(cuid())
  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  type            String // "INVOICE_PDF" | "CREDIT_NOTE_PDF" | "ATTACHMENT"
  storageProvider String    @default("RAILWAY_BUCKET")
  bucket          String
  objectKey       String    @unique
  fileName        String
  contentType     String
  byteSize        Int
  sha256          String
  isImmutable     Boolean   @default(true)
  createdById     String?
  createdAt       DateTime  @default(now())
  archivedAt      DateTime?

  emailDeliveries EmailDelivery[]

  @@index([invoiceId, type])
  @@index([sha256])
}

model OutboxEvent {
  id             String    @id @default(cuid())
  type           String // "INVOICE_PDF" | "INVOICE_EMAIL" | "REMINDER_EMAIL" | ...
  aggregateType  String
  aggregateId    String
  idempotencyKey String    @unique
  payload        Json
  status         String    @default("PENDING") // "PENDING" | "PROCESSING" | "DONE" | "FAILED"
  attempts       Int       @default(0)
  availableAt    DateTime  @default(now())
  lockedAt       DateTime?
  processedAt    DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  emailDelivery EmailDelivery?

  @@index([status, availableAt])
}

model EmailDelivery {
  id                String         @id @default(cuid())
  invoiceId         String
  invoice           Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  documentId        String?
  document          DocumentAsset? @relation(fields: [documentId], references: [id], onDelete: Restrict)
  outboxEventId     String?        @unique
  outboxEvent       OutboxEvent?   @relation(fields: [outboxEventId], references: [id], onDelete: Restrict)
  provider          String
  providerMessageId String?        @unique
  fromAddress       String
  toAddress         String
  subject           String
  status            String         @default("PENDING") // "PENDING" | "SENT" | "DELIVERED" | "FAILED" | "BOUNCED"
  attemptCount      Int            @default(0)
  lastAttemptAt     DateTime?
  nextAttemptAt     DateTime?
  sentAt            DateTime?
  deliveredAt       DateTime?
  errorCode         String?
  errorMessage      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([invoiceId, createdAt])
  @@index([status, nextAttemptAt])
}

model ImportBatch {
  id              String    @id @default(cuid())
  source          String // "OMEGA" | "SUPERFAKTURA" | "BANK_STATEMENT"
  fileName        String
  sha256          String
  mode            String // "DRY_RUN" | "COMMIT"
  status          String    @default("PENDING") // "PENDING" | "VALIDATED" | "COMMITTED" | "FAILED"
  partnerCount    Int       @default(0)
  invoiceCount    Int       @default(0)
  itemCount       Int       @default(0)
  totalGrossCents Int       @default(0)
  warningCount    Int       @default(0)
  errorCount      Int       @default(0)
  summary         Json?
  backupReference String?
  createdById     String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@unique([source, sha256, mode])
  @@index([source, status])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     String
  entityType String
  entityId   String
  beforeData Json?
  afterData  Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}

// Bezpečné číslovanie dokladov per rok+typ, id napr. "VYDANA-2026", "OBJ-2026", "SARZA-2026"
model DocCounter {
  id         String @id
  lastNumber Int    @default(0)
}

model EkasaSale {
  id              String   @id @default(cuid())
  saleDate        DateTime
  receiptNumber   String?
  description     String?
  productId       String?
  product         Product? @relation(fields: [productId], references: [id])
  quantity        Float    @default(1)
  totalGrossCents Int
  vatRate         Int      @default(20)
  importBatch     String // názov súboru + čas importu (dedup / undo)
  createdAt       DateTime @default(now())

  @@unique([receiptNumber, saleDate])
}

// ---------- Plnenie plánu ----------
// Skutočnosť sa vždy počíta live z faktúr/šarží — žiadne kešovanie.

model MonthlyPlan {
  id                    String   @id @default(cuid())
  year                  Int
  month                 Int
  targetRevenueCents    Int      @default(0)
  targetProductionUnits Int      @default(0)
  note                  String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([year, month])
}
